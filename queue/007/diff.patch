+"""Extractor protocol and implementations.
+
+Classes:
+  Extractor     â€” abstract base / Protocol for all extractors.
+  MockExtractor â€” deterministic scripted extractor for tests; no network.
+  LLMExtractor  â€” real Claude-backed extractor (lazy-imports anthropic).
+"""
+
+from __future__ import annotations
+
+import json
+import re
+from collections import deque
+from typing import Any, Protocol, runtime_checkable
+
+from structured_extract.schema import Schema
+
+
+@runtime_checkable
+class Extractor(Protocol):
+    """Protocol satisfied by any object with an ``extract`` method.
+
+    extract(text, schema) -> dict
+      text   â€” raw document text
+      schema â€” Schema describing desired output
+      returns a plain dict (may be incomplete / invalid; caller validates)
+    """
+
+    def extract(self, text: str, schema: Schema) -> dict:  # pragma: no cover
+        ...
+
+
+# ------------------------------------------------------------------ #
+# MockExtractor
+# ------------------------------------------------------------------ #
+
+
+class MockExtractor:
+    """Deterministic extractor for tests: returns scripted responses in order.
+
+    Args:
+        responses: An iterable of dicts.  Each call to ``extract`` pops the
+                   next response.  If exhausted, the last response is repeated.
+
+    Example::
+
+        mock = MockExtractor([
+            {"vendor": None, "amount": "not-a-number"},  # wrong first
+            {"vendor": "Acme", "amount": 42.0},          # correct second
+        ])
+    """
+
+    def __init__(self, responses: list[dict]) -> None:
+        if not responses:
+            raise ValueError("MockExtractor requires at least one response")
+        self._queue: deque[dict] = deque(responses)
+        self._last: dict = responses[-1]
+        self.call_count: int = 0
+        self.call_args: list[tuple[str, Schema]] = []
+
+    def extract(self, text: str, schema: Schema) -> dict:
+        self.call_count += 1
+        self.call_args.append((text, schema))
+        if self._queue:
+            result = self._queue.popleft()
+            self._last = result
+            return dict(result)  # return a copy so callers can't mutate internals
+        return dict(self._last)
+
+
+# ------------------------------------------------------------------ #
+# LLMExtractor (lazy-imports anthropic)
+# ------------------------------------------------------------------ #
+
+_SYSTEM_PROMPT = (
+    "You are a precise data-extraction assistant. "
+    "Given a document and a JSON schema, extract the requested fields and return "
+    "ONLY a valid JSON object that conforms to the schema. "
+    "Do not include markdown fences, commentary, or any text outside the JSON object."
+)
+
+_USER_TEMPLATE = """\
+## Document
+{text}
+
+## Target JSON Schema
+{json_schema}
+
+## Instructions
+Extract every field listed in the schema from the document above.
+Return ONLY the JSON object â€” no prose, no markdown fences.
+"""
+
+_CORRECTION_TEMPLATE = """\
+## Document
+{text}
+
+## Target JSON Schema
+{json_schema}
+
+## Previous extraction (contained errors)
+{previous}
+
+## Validation errors to fix
+{errors}
+
+## Instructions
+Correct the extraction so all listed errors are resolved.
+Return ONLY the corrected JSON object â€” no prose, no markdown fences.
+"""
+
+
+class LLMExtractor:
+    """Extractor backed by Anthropic's Claude API (lazy-imports anthropic).
+
+    anthropic is only imported when an instance is *used*, so importing this
+    module in offline/test environments is safe.
+
+    Args:
+        model: Claude model string (default ``claude-haiku-4-5``).
+        api_key: Anthropic API key.  Falls back to ``ANTHROPIC_API_KEY`` env var.
+        max_tokens: Maximum tokens for the completion (default 1024).
+        previous_result: If provided, used in the correction prompt path.
+        previous_errors: Matching error strings for the correction prompt.
+    """
+
+    def __init__(
+        self,
+        model: str = "claude-haiku-4-5",
+        api_key: str | None = None,
+        max_tokens: int = 1024,
+        previous_result: dict | None = None,
+        previous_errors: list[str] | None = None,
+    ) -> None:
+        self.model = model
+        self.api_key = api_key
+        self.max_tokens = max_tokens
+        self.previous_result = previous_result
+        self.previous_errors = previous_errors
+
+    def _get_client(self) -> Any:  # noqa: ANN401
+        try:
+            import anthropic  # type: ignore[import-untyped]
+        except ImportError as exc:
+            raise ImportError(
+                "anthropic package is required for LLMExtractor. "
+                "Install it with: pip install 'structured-extract[llm]'"
+            ) from exc
+        kwargs: dict[str, Any] = {}
+        if self.api_key:
+            kwargs["api_key"] = self.api_key
+        return anthropic.Anthropic(**kwargs)
+
+    def _build_prompt(self, text: str, schema: Schema) -> str:
+        json_schema_str = json.dumps(schema.to_json_schema(), indent=2)
+        if self.previous_result is not None and self.previous_errors:
+            return _CORRECTION_TEMPLATE.format(
+                text=text,
+                json_schema=json_schema_str,
+                previous=json.dumps(self.previous_result, indent=2),
+                errors="\n".join(f"- {e}" for e in self.previous_errors),
+            )
+        return _USER_TEMPLATE.format(text=text, json_schema=json_schema_str)
+
+    def extract(self, text: str, schema: Schema) -> dict:
+        client = self._get_client()
+        prompt = self._build_prompt(text, schema)
+        message = client.messages.create(
+            model=self.model,
+            max_tokens=self.max_tokens,
+            system=_SYSTEM_PROMPT,
+            messages=[{"role": "user", "content": prompt}],
+        )
+        if message.stop_reason == "refusal":
+            raise ValueError("LLM refused to extract: stop_reason='refusal'")
+        text = next(
+            (b.text for b in message.content if getattr(b, "type", None) == "text"),
+            None,
+        )
+        if text is None:
+            raise ValueError(
+                "LLM response contained no text block "
+                f"(content types: {[getattr(b, 'type', None) for b in message.content]})"
+            )
+        raw = text.strip()
+        # Strip accidental markdown fences if the model added them
+        if raw.startswith("```"):
+            raw = re.sub(r"^```[a-z]*\n?", "", raw)
+            raw = re.sub(r"\n?```$", "", raw)
+        return json.loads(raw)
